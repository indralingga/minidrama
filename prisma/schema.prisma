generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  SHORT
  DRAMA
  FILM
  ANIME
}

model Provider {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  category     Category
  iconUrl      String?
  apiBaseUrl   String   // The base URL for the CUTAD API for this provider
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  image     String?
  role      String   @default("USER") // USER, ADMIN
  coinBalance Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  bookmarks Bookmark[]
  unlocks   UnlockedEpisode[]
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  dramaId   String   // ID from the provider
  providerSlug String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, dramaId, providerSlug])
}

model UnlockedEpisode {
  id        String   @id @default(cuid())
  userId    String
  dramaId   String
  episode   Int
  providerSlug String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, dramaId, episode, providerSlug])
}
